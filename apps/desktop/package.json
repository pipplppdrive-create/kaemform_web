{
  "name": "@kaemform/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "KaemForm Desktop document generation workspace",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.cjs dev",
    "start": "npm run dev",
    "build": "npm run type-check && electron-vite build",
    "preview": "node scripts/run-electron-vite.cjs preview",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "package": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@supabase/supabase-js": "^2.45.4",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "docxtemplater": "^3.52.0",
    "exceljs": "^4.4.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.451.0",
    "nanoid": "^5.0.7",
    "pizzip": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwind-merge": "^2.5.3",
    "ws": "^8.21.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "31.7.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}

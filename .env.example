# Supabase KaemForm
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth bridge from Kaemnur to KaemForm.
LAUNCH_TOKEN_SECRET=

# External Kaemnur license API.
KAEMNUR_API_URL=
KAEMNUR_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_KAEMNUR_URL=https://kaemnur.com
KAEMNUR_PRODUCT_URL=https://www.kaemnur.com/products/KaemForm

# Kaemnur web auth overrides (optional)
KAEMNUR_WEB_LOGIN_URL=
KAEMNUR_REGISTER_URL=

# Hidden manual admin fallback (/admin). Keep server-only.
KAEMFORM_ADMIN_USERNAME=kaemnur
KAEMFORM_ADMIN_PASSWORD_SHA256=
KAEMFORM_ADMIN_EMAIL=kaemnur-admin@kaemform.local
KAEMFORM_ADMIN_KAEMNUR_UID=00000000-0000-4000-8000-000000000095

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# Cron
CRON_SECRET=
